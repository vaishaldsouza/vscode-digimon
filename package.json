{
  "name": "vscode-digimon",
  "displayName": "VS Code Digimon",
  "description": "Digimon companions for your VS Code — walk, idle, and keep you company while you code!",
  "version": "0.1.0",
  "publisher": "digi-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaishaldsouza/vscode-digimon"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "digimon.viewport",
          "name": "Digital World"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-digimon.start",
        "title": "Start Digimon Session",
        "category": "Digimon"
      },
      {
        "command": "vscode-digimon.spawn",
        "title": "Spawn Digimon",
        "category": "Digimon",
        "icon": "$(add)"
      },
      {
        "command": "vscode-digimon.remove-all",
        "title": "Remove All Digimon",
        "category": "Digimon",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscode-digimon.spawn",
          "when": "view == digimon.viewport",
          "group": "navigation@1"
        },
        {
          "command": "vscode-digimon.remove-all",
          "when": "view == digimon.viewport",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "VS Code Digimon",
      "properties": {
        "vscode-digimon.digimonType": {
          "type": "string",
          "default": "agumon",
          "enum": [
            "agumon",
            "gabumon",
            "patamon"
          ],
          "enumDescriptions": [
            "Agumon — fire-breathing Rookie",
            "Gabumon — ice-blasting wolf-pelt Rookie",
            "Patamon — adorable flying hamster Rookie"
          ],
          "description": "Default Digimon type"
        },
        "vscode-digimon.digimonSize": {
          "type": "string",
          "default": "medium",
          "enum": [
            "small",
            "medium",
            "large"
          ],
          "enumDescriptions": [
            "Small (48px)",
            "Medium (64px)",
            "Large (96px)"
          ],
          "description": "Sprite size"
        },
        "vscode-digimon.speedMultiplier": {
          "type": "number",
          "default": 1,
          "minimum": 0.5,
          "maximum": 3,
          "description": "Walking speed multiplier (base speed × this value)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "gen-assets": "py scripts/gen_assets.py"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "gifwrap": "^0.10.1"
  }
}